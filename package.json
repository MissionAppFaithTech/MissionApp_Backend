{
  "name": "mission-app",
  "version": "1.1.0",
  "type": "module",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "scripts": {
    "build": "tsup",
    "start:dev": "tsx watch --env-file=.env --no-deprecation src/server.ts",
    "start:prod": "node --enable-source-maps --env-file=.env dist/server.js",
    "start:prod:docker": "node --enable-source-maps dist/server.js",
    "ci:build": "rimraf dist && tsc",
    "ci:lint": "npm run lint:fix:prisma && npm run lint:fix:src",
    "ci:format": "npm run format:prisma && npm run format:src",
    "lint:src": "eslint src/**/*.{js,ts,tsx,jsx,cjs}",
    "lint:prisma": "eslint prisma/**/*.{js,ts,tsx,jsx,cjs}",
    "lint:fix:src": "eslint --fix src/**/*.{js,ts,tsx,jsx,cjs}",
    "lint:fix:prisma": "eslint --fix prisma/**/*.{js,ts,tsx,jsx,cjs}",
    "format:src": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'src/**/*.{js,ts,tsx,jsx,cjs}'",
    "format:prisma": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'prisma/**/*.{js,ts,tsx,jsx,cjs}'",
    "husky": "husky",
    "husky:install": "husky install",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force --skip-seed",
    "db:seed": "prisma db seed",
    "db:reset:all": "rimraf prisma/migrations && npm run db:migrate:reset && npm run db:migrate:dev:default && prisma generate && npm run db:seed",
    "db:deploy": "prisma migrate deploy && prisma generate && npm run db:seed"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "19.8.1",
    "@swc/core": "1.13.5",
    "@types/elasticsearch": "5.0.43",
    "@types/fs-extra": "11.0.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.5.1",
    "@types/nodemailer": "7.0.1",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "commitlint": "19.8.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard-with-typescript": "43.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-promise": "6.6.0",
    "eslint-plugin-unicorn": "51.0.1",
    "husky": "9.1.7",
    "pino-pretty": "13.1.1",
    "prettier": "3.6.2",
    "prettier-plugin-prisma": "5.0.0",
    "prisma": "6.16.2",
    "rimraf": "6.0.1",
    "ts-node": "10.9.2",
    "tsup": "8.5.0",
    "tsx": "4.20.6",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "@elastic/elasticsearch": "9.1.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.1.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.2.1",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "8.2.0",
    "@prisma/client": "6.16.2",
    "bcryptjs": "3.0.2",
    "cpf-cnpj-validator": "1.0.3",
    "date-fns": "4.1.0",
    "dotenv": "17.2.2",
    "fastify": "5.6.1",
    "fastify-cookie": "5.7.0",
    "fastify-multer": "2.0.3",
    "firebase": "12.0.0",
    "fs-extra": "11.3.2",
    "ioredis": "5.8.0",
    "jsonwebtoken": "9.0.2",
    "node-cron": "4.2.1",
    "nodemailer": "7.0.6",
    "pino": "9.9.2",
    "sharp": "0.34.3",
    "uuid": "12.0.0",
    "zod": "4.1.11"
  }
}
